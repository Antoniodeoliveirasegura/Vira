# Vira environment variables. Copy to .env.local and fill in.
# Do NOT commit real values (.env* is gitignored).

# Anthropic / Claude (note classification + AI day suggestions)
ANTHROPIC_API_KEY=

# Supabase project (use the anon / public key, never the service_role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth (Calendar read access)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Single-user app auth
APP_PASSWORD=
APP_SESSION_SECRET=

# Email digest delivery (daily reminders + resurfacing when the app is closed)
# Resend API key — https://resend.com (free tier sends from onboarding@resend.dev to your own address)
RESEND_API_KEY=
DIGEST_TO_EMAIL=        # where the digest is sent (your email)
DIGEST_FROM_EMAIL=      # optional; defaults to "Vira <onboarding@resend.dev>"

# Deploy-only: Vercel Cron sends this as a Bearer token to /api/cron/digest.
# Set it in Vercel so the cron endpoint isn't publicly triggerable. Unset locally = open (for testing).
CRON_SECRET=
# Optional public app URL, used for the "Open Vira" link in the digest email.
APP_URL=
