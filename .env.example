# Vira environment variables. Copy to .env.local and fill in.
# Do NOT commit real values (.env* is gitignored).

# Anthropic / Claude (note classification + AI day suggestions)
ANTHROPIC_API_KEY=

# Supabase project (use the anon / public key, never the service_role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth (Calendar read access)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Single-user app auth
APP_PASSWORD=
APP_SESSION_SECRET=
